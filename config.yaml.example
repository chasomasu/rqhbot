# RqhBot 配置文件
# 复制此文件为 config.yaml 并填入实际配置

# NapCat 连接配置
napcat:
  ws_url: "ws://localhost:3002"          # NapCat WebSocket 地址
  access_token: ""                        # 访问令牌（从 NapCat 获取）
  bot_uin: ""                             # 机器人 QQ 号
  root: ""                                # 管理员 QQ 号
  webui_uri: "http://localhost:6098"      # WebUI 地址
  webui_token: ""                         # WebUI 令牌

# 机器人配置
bot:
  # 是否加载插件系统
  load_plugins: true
  # 插件目录路径
  plugin_dir: "plugins"

# 日志配置
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
  log_dir: "log"
  log_file: "bot.log"

# 其他配置
settings:
  # 调试模式
  debug: false
  # 自动重连
  auto_reconnect: true
  # 重连间隔（秒）
  reconnect_interval: 5
