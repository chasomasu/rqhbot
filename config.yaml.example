# RqhBot 配置文件
# 复制此文件为 config.yaml 并填入实际配置

# NapCat 连接配置
# ⚠️ Windows 注意：localhost 可能优先解析为 IPv6 (::1)，导致 NapCat 连接失败。
#    代码会自动将 localhost 替换为 127.0.0.1（仅 Windows），你也可以直接写 127.0.0.1。
napcat:
  ws_url: "ws://localhost:3002"          # NapCat WebSocket 地址（建议 Win 上直接用 127.0.0.1）
  access_token: ""                        # 访问令牌（从 NapCat 获取）
  bot_uin: ""                             # 机器人 QQ 号
  root: ""                                # 管理员 QQ 号
  webui_uri: "http://localhost:6098"      # WebUI 地址
  webui_token: ""                         # WebUI 令牌

# 机器人配置
bot:
  # 是否加载插件系统
  load_plugins: true
  # 插件目录路径
  plugin_dir: "plugins"

# 日志配置
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
  log_dir: "log"
  log_file: "bot.log"

# 其他配置
settings:
  # 调试模式
  debug: false
  # 自动重连
  auto_reconnect: true
  # 重连间隔（秒）
  reconnect_interval: 5
